# OpenSky Network — OAuth2 client credentials
# Create an API client at: https://opensky-network.org/my-opensky -> Client Credentials
OPENSKY_CLIENT_ID=your_client_id_here
OPENSKY_CLIENT_SECRET=your_client_secret_here

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=planelogistics
POSTGRES_USER=planelogistics
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://planelogistics:changeme@postgres:5432/planelogistics

# Redis
REDIS_URL=redis://redis:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/flights

# Phase 6: EIA API key for fuel/crude prices (free at https://www.eia.gov/opendata/)
EIA_API_KEY=

# Optional: AirLabs API key for full SWISS route database (free at https://airlabs.co)
# Without this key, routes are learned automatically from flight data (takes 1-2 days).
# With this key, all SWISS routes are loaded on startup in one API call.
AIRLABS_API_KEY=

# Collect mode: set to true for minimal-resource data collection.
# Runs only: OpenSky poll (30s) → enrich → Postgres + flight aggregation.
# Skips: Redis cache, WebSocket, KPI computation, unit economics.
# Usage: COLLECT_MODE=true docker compose up postgres backend
COLLECT_MODE=false
