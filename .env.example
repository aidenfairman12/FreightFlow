# ── PostgreSQL (used by docker-compose + backend) ────────────────────────────
POSTGRES_DB=freightflow
POSTGRES_USER=freightflow
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://freightflow:changeme@postgres:5432/freightflow

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend ───────────────────────────────────────────────────────────────────
# CORS origin for the frontend
FRONTEND_URL=http://localhost:3000

# EIA API key for diesel & crude oil prices (free at https://www.eia.gov/opendata/register.php)
# Without this, economic factor cards will show "Not yet fetched"
EIA_API_KEY=

# FRED API key for freight TSI index (free at https://fred.stlouisfed.org/docs/api/api_key.html)
# Without this, freight TSI indicator will show "Not yet fetched"
FRED_API_KEY=

# FAF5 data directory (relative to backend/)
FAF5_DATA_DIR=data/faf5
