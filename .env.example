# OpenSky Network — OAuth2 client credentials
# Create an API client at: https://opensky-network.org/my-opensky -> Client Credentials
OPENSKY_CLIENT_ID=your_client_id_here
OPENSKY_CLIENT_SECRET=your_client_secret_here

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=planelogistics
POSTGRES_USER=planelogistics
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://planelogistics:changeme@postgres:5432/planelogistics

# Redis
REDIS_URL=redis://redis:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/flights
